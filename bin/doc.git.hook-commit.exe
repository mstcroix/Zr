#!/usr/bin/env bash
# tools/doc.git.hook-commit.exe
# ─────────────────────────────────────────────────────────────────────────────
# Git pre-commit hook: keeps README.md "## Journal Entries" in sync with
# every file found under journal/*.md — sorted by git commit order.
#
# Wired in as: .git/hooks/pre-commit → delegates to this file.
# Version-controlled at: tools/ (not .git/ — survives clone)
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
README="$REPO_ROOT/README.md"
JOURNAL_DIR="$REPO_ROOT/mnt/journal"

# ── 1. Build the new Journal Entries block ────────────────────────────────────
new_block="## Journal Entries\n"

if ls "$JOURNAL_DIR"/*.md 1>/dev/null 2>&1; then
    committed_files=$(git log --name-only --diff-filter=A --format="" --reverse -- "mnt/journal/*.md" 2>/dev/null | grep -v '^$' || true)
    all_files=$(ls -1 "$JOURNAL_DIR"/*.md | sed "s|$REPO_ROOT/||")
    new_files=$(comm -23 <(echo "$all_files" | sort) <(echo "$committed_files" | sort))
    ordered="${committed_files}${new_files:+$'\n'$new_files}"

    while IFS= read -r relpath; do
        [[ -z "$relpath" ]] && continue
        filepath="$REPO_ROOT/$relpath"
        [[ ! -f "$filepath" ]] && continue
        filename="$(basename "$filepath")"
        date_part="${filename:0:10}"
        title=$(grep -m1 '^# ' "$filepath" | sed 's/^# //')
        new_block="${new_block}\n- [${date_part} — ${title}](mnt/journal/${filename})"
    done <<< "$ordered"
else
    new_block="${new_block}\n*(no entries yet)*"
fi

new_block="${new_block}\n"

# ── 2. Replace the Journal Entries section in README.md ──────────────────────
awk -v new_block="$new_block" '
    /^## Journal Entries$/ { in_section=1; printf "%s", new_block; next }
    in_section && /^---$/  { in_section=0; print; next }
    in_section             { next }
    { print }
' "$README" > "$README.tmp"

# ── 3. Stage README.md only if changed (idempotent) ──────────────────────────
if ! diff -q "$README" "$README.tmp" > /dev/null 2>&1; then
    mv "$README.tmp" "$README"
    git add "$README"
    echo "[hook] README.md Journal Entries updated and staged."
else
    rm "$README.tmp"
fi

exit 0
